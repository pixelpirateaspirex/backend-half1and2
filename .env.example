# ══════════════════════════════════════════════════════════════════════
#  PIXEL PIRATES — BACKEND ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── SERVER ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # change to "production" on live server

# ── MONGODB ───────────────────────────────────────────────────────────
# Free cluster: https://cloud.mongodb.com → New Project → Free Tier
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/pixel-pirates?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client ID → Web Application
# Authorized JS origins: http://localhost:3000
# Authorized redirect URIs: http://localhost:3000
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── STRIPE ────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys (use test keys for development)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
# Webhook secret: Stripe Dashboard → Webhooks → Add endpoint
# Events to listen: checkout.session.completed, invoice.payment_succeeded,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# ── EMAIL / NODEMAILER ────────────────────────────────────────────────
# Gmail App Password (NOT your regular Gmail password):
#   Google Account → Security → 2-Step Verification → App passwords
#   → Generate for "Mail" → copy the 16-character password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false            # true only if port is 465
EMAIL_USER=pixelpirateaspirex@gmail.com
EMAIL_PASS=REPLACE_WITH_16_CHAR_GMAIL_APP_PASSWORD
EMAIL_FROM="Pixel Pirates" <pixelpirateaspirex@gmail.com>

# ── CLIENT (FRONTEND) URL ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── EXTERNAL APIs ─────────────────────────────────────────────────────
OMDB_API_KEY=trilogy
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
# RAWG Games API: https://rawg.io/apidocs → Get API Key (free)
RAWG_API_KEY=REPLACE_WITH_YOUR_RAWG_API_KEY
